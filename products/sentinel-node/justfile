set fallback := true

# supply chain policy: no third-party binary substitutes
# all packages are built from source or pulled from the trusted internal
# cache only. this ensures full provenance over every artifact in the image.
_nix_build := "nix build --option substitute true --option substituters https://nix.charemma.de/main"

_default:
    @just --list

# build sd card image (from source, trusted cache only)
build:
    {{ _nix_build }} -o ../../results/sentinel-node --builders "$(just _builders)" .#nixosConfigurations.sentinel-node.config.system.build.sdImage

# flash sd card image (usage: just flash /dev/sdX)
flash device:
    zstdcat ../../results/sentinel-node/sd-image/*.img.zst | sudo dd of={{device}} bs=4M status=progress conv=fsync

# publish build closure to internal cache
publish-cache:
    just publish-cache sentinel-node

# build x86 QEMU VM
_vm-build:
    {{ _nix_build }} -o ../../results/sentinel-node-vm .#nixosConfigurations.sentinel-node-vm.config.system.build.vm

# run VM bridged to host network (gets own IP, sees real traffic)
vm interface="br0": _vm-build
    sudo QEMU_NET_OPTS="-netdev bridge,id=net0,br={{interface}} -device virtio-net-pci,netdev=net0" \
        ../../results/sentinel-node-vm/bin/run-sentinel-node-vm

# deploy config to running device over SSH
deploy:
    nixos-rebuild switch --flake ".#sentinel-node" --target-host iot@sentinel-node --build-host iot@sentinel-node --use-remote-sudo

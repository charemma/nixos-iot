set fallback := true

_default:
    @just --list

# install node dependencies
init:
    npm install

# spin up all configured builders
up: init
    pulumi up --yes
    @echo ""
    @echo "Run 'eval \$(just builder::env)' to configure your shell for building."

# tear down all builders
down:
    pulumi destroy --yes

# export builder environment variables for eval
env:
    #!/usr/bin/env bash
    set -euo pipefail
    OUTPUT=$(pulumi stack output output 2>/dev/null || echo "[]")
    BUILDERS=""
    for row in $(echo "$OUTPUT" | jq -c '.[]'); do
        HOST=$(echo "$row" | jq -r '.host')
        USER=$(echo "$row" | jq -r '.user')
        ARCH=$(echo "$row" | jq -r '.arch')
        CORES=$(echo "$row" | jq -r '.cores')
        # fetch host key and base64 encode it (field 8 in builder format)
        HOSTKEY=$(ssh-keyscan -t ed25519 "$HOST" 2>/dev/null | grep ssh-ed25519 | awk '{print $3}')
        if [ -z "$HOSTKEY" ]; then
            echo "warning: could not fetch host key for $HOST" >&2
            continue
        fi
        # format: uri systems ssh-identity max-jobs speed-factor supported-features mandatory-features public-host-key
        BUILDERS+="ssh://${USER}@${HOST} ${ARCH} /etc/nix/builder_ed25519 ${CORES} 1 - - ${HOSTKEY};"
    done
    BUILDERS="${BUILDERS%;}"
    echo "export NIX_BUILDERS=\"$BUILDERS\""

# show running builders as JSON
status:
    @pulumi stack output output 2>/dev/null | jq . || echo "[]"

# review changes without applying
plan:
    pulumi preview

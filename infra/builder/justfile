set fallback := true

_default:
    @just --list

# install node dependencies
init:
    npm install

# spin up all configured builders and register host keys
up: init
    pulumi up --yes
    #!/usr/bin/env bash
    set -euo pipefail
    HOSTS=$(pulumi stack output output 2>/dev/null | jq -r '.[].host')
    for host in $HOSTS; do
        echo "Registering host key for $host..."
        sudo ssh-keyscan -t ed25519 "$host" 2>/dev/null | sudo tee -a /etc/ssh/ssh_known_hosts > /dev/null
    done
    echo ""
    echo "Run 'eval \$(just builder::env)' to configure your shell for building."

# tear down all builders and clean up host keys
down:
    #!/usr/bin/env bash
    set -euo pipefail
    HOSTS=$(pulumi stack output output 2>/dev/null | jq -r '.[].host')
    pulumi destroy --yes
    for host in $HOSTS; do
        sudo ssh-keygen -R "$host" -f /etc/ssh/ssh_known_hosts 2>/dev/null || true
    done

# export builder environment variables for eval
env:
    #!/usr/bin/env bash
    set -euo pipefail
    OUTPUT=$(pulumi stack output output 2>/dev/null || echo "[]")
    BUILDERS=$(echo "$OUTPUT" | jq -r '.[] | "ssh://\(.user)@\(.host) \(.arch) - - - - /etc/nix/builder_ed25519"')
    echo "export NIX_BUILDERS=\"$BUILDERS\""

# show running builders as JSON
status:
    @pulumi stack output output 2>/dev/null | jq . || echo "[]"

# review changes without applying
plan:
    pulumi preview

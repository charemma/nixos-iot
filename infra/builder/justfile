set fallback := true

_default:
    @just --list

# install node dependencies
init:
    npm install

# spin up all configured builders
up: init
    pulumi up --yes
    @echo ""
    @echo "Run 'eval \$(just builder::env)' to configure your shell for building."

# tear down all builders
down:
    pulumi destroy --yes

# export builder environment variables for eval
env:
    #!/usr/bin/env bash
    set -euo pipefail
    OUTPUT=$(pulumi stack output output 2>/dev/null || echo "[]")
    # format: uri systems ssh-identity max-jobs speed-factor supported-features mandatory-features
    BUILDERS=$(echo "$OUTPUT" | jq -r '.[] | "ssh://\(.user)@\(.host) \(.arch) /etc/nix/builder_ed25519 \(.cores) 1 - -"')
    echo "export NIX_BUILDERS=\"$BUILDERS\""
    echo "export NIX_SSHOPTS=\"-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null\""

# show running builders as JSON
status:
    @pulumi stack output output 2>/dev/null | jq . || echo "[]"

# review changes without applying
plan:
    pulumi preview

set fallback := true

_default:
    @just --list

_conf := justfile_directory() / "builders.conf"

# install node dependencies
init:
    npm install

# spin up all configured builders and register them
up: init
    pulumi up --yes
    pulumi stack output output 2>/dev/null \
        | jq -r '.[] | "ssh://\(.user)@\(.host) \(.arch) - - - - /etc/nix/builder_ed25519"' \
        > {{ _conf }}
    @echo "Registered $(wc -l < {{ _conf }}) cloud builder(s) in builders.conf"

# tear down all builders and clean up
down:
    pulumi destroy --yes
    rm -f {{ _conf }}
    @echo "Removed builders.conf"

# show running builders as JSON
status:
    @pulumi stack output output 2>/dev/null | jq . || echo "[]"

# review changes without applying
plan:
    pulumi preview
